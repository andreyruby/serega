#!/usr/bin/env bash
set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

log() { echo -e "${GREEN}[$(date +'%H:%M:%S')] $1${NC}"; }
warn() { echo -e "${YELLOW}[$(date +'%H:%M:%S')] $1${NC}"; }
error() { echo -e "${RED}[$(date +'%H:%M:%S')] $1${NC}"; exit 1; }

# Check if version argument provided
if [ $# -eq 0 ]; then
    error "Usage: $0 <version> [--dry-run]"
fi

VERSION=$1
DRY_RUN=${2:-}

if [[ "$DRY_RUN" == "--dry-run" ]]; then
    warn "DRY RUN MODE - No actual changes will be made"
    DRY_RUN=true
else
    DRY_RUN=false
fi

# Validate version format (semantic versioning)
if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    error "Version must be in format X.Y.Z (e.g., 1.2.3)"
fi

log "Starting release process for version $VERSION"

# Step 1: Check documentation
log "Checking documentation coverage..."
if ! yard doc --no-cache --quiet && yard stats --list-undoc | grep -q "100.00% documented"; then
    error "Documentation is not 100% complete"
fi

# Step 2: Install dependencies and run tests
log "Installing dependencies..."
pip3 install codespell || warn "codespell installation failed"
gem update --system
bundle update && bundle update --bundler

# Define gemfiles to test
GEMFILES=("5.2" "6.1" "7.2" "8.0")

log "Updating all gemfiles..."
for gemfile in "${GEMFILES[@]}"; do
    if [ -f "gemfiles/${gemfile}.gemfile" ]; then
        log "Updating gemfile ${gemfile}..."
        # Backup original bundler version
        BUNDLER_VERSION=$(grep -A1 "BUNDLED WITH" "gemfiles/${gemfile}.gemfile.lock" | tail -n1 | xargs || echo "")
        BUNDLE_GEMFILE="gemfiles/${gemfile}.gemfile" bundle update
        # Restore original bundler version if it existed
        if [ -n "$BUNDLER_VERSION" ]; then
            sed -i "/BUNDLED WITH/,+1c\BUNDLED WITH\n   $BUNDLER_VERSION" "gemfiles/${gemfile}.gemfile.lock"
        fi
    else
        warn "Gemfile gemfiles/${gemfile}.gemfile not found, skipping"
    fi
done

log "Running tests and checks..."
bundle exec rspec || error "Tests failed"
bundle exec rubocop -A || error "Rubocop failed"
bundle exec rake examples || error "Examples failed"
codespell --skip="./sig,./doc,./coverage" || error "Codespell found issues"

# Step 3: Update version
log "Updating version to $VERSION..."
if [ "$DRY_RUN" = false ]; then
    echo "$VERSION" > VERSION
fi

# Step 4: Create release branch
BRANCH_NAME="v$VERSION"
log "Creating release branch: $BRANCH_NAME"
if [ "$DRY_RUN" = false ]; then
    git checkout -b "$BRANCH_NAME" || error "Failed to create branch"
fi

# Step 5: Build gem
log "Building gem..."
if [ "$DRY_RUN" = false ]; then
    gem build serega.gemspec || error "Gem build failed"
fi

# Step 6: Final validation (same as step 2, but let's make it a function)
run_full_test_suite() {
    log "Running final test suite..."
    bundle update
    for gemfile in "${GEMFILES[@]}"; do
        if [ -f "gemfiles/${gemfile}.gemfile" ]; then
            # Backup original bundler version
            BUNDLER_VERSION=$(grep -A1 "BUNDLED WITH" "gemfiles/${gemfile}.gemfile.lock" | tail -n1 | xargs || echo "")
            BUNDLE_GEMFILE="gemfiles/${gemfile}.gemfile" bundle update
            # Restore original bundler version if it existed
            if [ -n "$BUNDLER_VERSION" ]; then
                sed -i "/BUNDLED WITH/,+1c\BUNDLED WITH\n   $BUNDLER_VERSION" "gemfiles/${gemfile}.gemfile.lock"
            fi
        fi
    done
    bundle exec rspec
    bundle exec rubocop -A
    bundle exec rake examples
    codespell --skip="./sig,./doc,./coverage"
}

run_full_test_suite || error "Final test suite failed"

# Step 7: Validate documentation files
log "Validating markdown files..."
if command -v mdl &> /dev/null; then
    mdl README.md RELEASE.md CHANGELOG.md || error "Markdown validation failed"
else
    warn "mdl not installed, skipping markdown validation"
fi

# Step 8: Commit changes
log "Committing changes..."
if [ "$DRY_RUN" = false ]; then
    git add .
    git commit -m "Release v$VERSION" || error "Commit failed"
    git push origin "$BRANCH_NAME" || error "Push failed"
fi

log "Release preparation complete!"
log "Next steps:"
log "1. Create and merge PR for branch $BRANCH_NAME"
log "2. Run: $0 --finalize $VERSION"

# If --finalize flag is passed, complete the release
if [[ "${2:-}" == "--finalize" ]]; then
    log "Finalizing release..."
    if [ "$DRY_RUN" = false ]; then
        git checkout master
        git pull --rebase origin master
        git tag -a "v$VERSION" -m "v$VERSION"
        git push origin master
        git push origin --tags
        gem push "serega-$VERSION.gem"
    fi
    log "Release $VERSION completed!"
fi